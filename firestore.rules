rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════
    //  YARDIMCI FONKSİYONLAR
    // ═══════════════════════════════════════════

    // Kullanıcı giriş yapmış mı?
    function isAuth() {
      return request.auth != null;
    }

    // Belirtilen UID'nin sahibi mi?
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // Admin mi? (settings/admins belgesindeki uids listesinden kontrol)
    function isAdmin() {
      return isAuth() &&
        exists(/databases/$(database)/documents/settings/admins) &&
        request.auth.uid in get(/databases/$(database)/documents/settings/admins).data.uids;
    }

    // Veri boyutu sınırı (DoS koruması)
    function isReasonableSize() {
      return request.resource.size() < 1048576; // 1MB
    }

    // ═══════════════════════════════════════════
    //  CONFIG — API anahtarları ve ayarlar
    // ═══════════════════════════════════════════
    // Sadece admin okuyabilir/yazabilir.
    // Cloud Functions service account her zaman erişebilir.

    match /config/{configId} {
      allow read: if isAdmin();
      allow write: if isAdmin() && isReasonableSize();
    }

    // ═══════════════════════════════════════════
    //  SETTINGS — Uygulama ayarları
    // ═══════════════════════════════════════════

    match /settings/{settingId} {
      // admins belgesi: sadece admin yazabilir
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════
    //  USERS — Kullanıcı profilleri
    // ═══════════════════════════════════════════

    match /users/{userId} {
      // Kendi profilini okuyabilir/yazabilir
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && isReasonableSize();
      allow delete: if isOwner(userId) || isAdmin();

      // Alt koleksiyonlar (data chunks — sync)
      match /{subcollection=**} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && isReasonableSize();
      }
    }

    // ═══════════════════════════════════════════
    //  PROFILES — Arkadaşlık sistemi profilleri
    // ═══════════════════════════════════════════

    match /profiles/{userId} {
      // Herkes profilleri okuyabilir (arkadaş kodu aramak için)
      allow read: if isAuth();
      // Kendi profilini oluşturabilir/güncelleyebilir
      allow create: if isOwner(userId) && isReasonableSize();
      allow update: if isOwner(userId) && isReasonableSize();
      allow delete: if isOwner(userId);

      // Alt koleksiyonlar (friends)
      match /friends/{friendId} {
        allow read: if isAuth();
        allow write: if isAuth() && isReasonableSize();
      }
    }

    // ═══════════════════════════════════════════
    //  FOODS — Kullanıcı eklediği yemekler
    // ═══════════════════════════════════════════

    match /foods/{foodId} {
      allow read: if isAuth();
      allow create: if isAuth() && isReasonableSize();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════
    //  CROWD_FOODS — Topluluk yemekleri
    // ═══════════════════════════════════════════

    match /crowd_foods/{foodId} {
      allow read: if isAuth();
      allow create: if isAuth() && isReasonableSize();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════
    //  USER_FEEDBACKS — Kullanıcı geri bildirimleri
    // ═══════════════════════════════════════════

    match /user_feedbacks/{feedbackId} {
      allow read: if isAuth()
        && resource.data.userId == request.auth.uid;
      allow update: if isAuth()
        && resource.data.userId == request.auth.uid;
      allow create: if isAdmin();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════
    //  USER_DATA — Beslenme verileri (sync)
    // ═══════════════════════════════════════════

    match /user_data/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && isReasonableSize();

      // Alt koleksiyonlar (günlük veriler, chunk'lar vs.)
      match /{subcollection=**} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && isReasonableSize();
      }
    }

    // ═══════════════════════════════════════════
    //  RECIPES — Tarifler
    // ═══════════════════════════════════════════

    match /recipes/{recipeId} {
      // Herkes okuyabilir (giriş yapmış kullanıcılar)
      allow read: if isAuth();
      // Sadece admin ekleyebilir/düzenleyebilir/silebilir
      allow create: if isAdmin() && isReasonableSize();
      allow update: if isAdmin() && isReasonableSize();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════
    //  COMMUNITY_RECIPES — AI ile üretilmiş paylaşımlı tarifler
    // ═══════════════════════════════════════════
    // Cloud Function submitCommunityRecipe yazar. Client okuyabilir.

    match /community_recipes/{recipeKey} {
      allow read: if isAuth();
      allow write: if false; // Sadece Cloud Functions
    }

    // ═══════════════════════════════════════════
    //  COMMUNITY — Topluluk paylaşımları
    // ═══════════════════════════════════════════

    match /community_posts/{postId} {
      // Giriş yapmış herkes okuyabilir
      allow read: if isAuth();
      // Kendi paylaşımını oluşturabilir
      allow create: if isAuth()
        && request.resource.data.uid == request.auth.uid
        && isReasonableSize();
      // Kendi paylaşımını güncelleyebilir (beğeni hariç - aşağıda)
      // veya herkes beğeni alanını güncelleyebilir
      allow update: if isAuth() && isReasonableSize();
      // Sadece paylaşım sahibi veya admin silebilir
      allow delete: if isAuth()
        && (resource.data.uid == request.auth.uid || isAdmin());
    }

    // ═══════════════════════════════════════════
    //  FOOD REQUESTS — Yemek istekleri
    // ═══════════════════════════════════════════

    match /food_requests/{requestId} {
      allow read: if isAuth();
      allow create: if isAuth() && isReasonableSize();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════
    //  TICKETS — Destek talepleri
    // ═══════════════════════════════════════════

    match /tickets/{ticketId} {
      allow read: if isAuth()
        && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAuth()
        && request.resource.data.uid == request.auth.uid
        && isReasonableSize();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════
    //  REPORTS — İçerik raporları
    // ═══════════════════════════════════════════

    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuth() && isReasonableSize();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════
    //  SOFRAS — Aile/ev paylaşımlı plan + market listesi
    // ═══════════════════════════════════════════
    // Sofra: birden çok kullanıcının paylaştığı haftalık menü ve market listesi.
    // Mahremiyet: kilo/kalori/makro HİÇBİR zaman burada tutulmaz.

    match /sofras/{sofraId} {
      // Okuma: sadece üyeler
      allow read: if isAuth()
        && request.auth.uid in resource.data.memberIds;

      // Oluşturma: kurucu kendini owner ve memberIds'e eklemiş olmalı
      allow create: if isAuth()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.memberIds is list
        && request.auth.uid in request.resource.data.memberIds
        && isReasonableSize();

      // Güncelleme: mevcut üyelerden biri olmalı
      // (Davet/katılma akışı S2'de Cloud Function ile eklenecek)
      allow update: if isAuth()
        && request.auth.uid in resource.data.memberIds
        && isReasonableSize();

      // Silme: sadece sahibi
      allow delete: if isAuth()
        && resource.data.ownerId == request.auth.uid;

      // Alt koleksiyonlar: plans/, shoppingLists/
      match /{subpath=**} {
        allow read: if isAuth()
          && exists(/databases/$(database)/documents/sofras/$(sofraId))
          && request.auth.uid in get(/databases/$(database)/documents/sofras/$(sofraId)).data.memberIds;
        allow write: if isAuth()
          && exists(/databases/$(database)/documents/sofras/$(sofraId))
          && request.auth.uid in get(/databases/$(database)/documents/sofras/$(sofraId)).data.memberIds
          && isReasonableSize();
      }
    }

    // ═══════════════════════════════════════════
    //  INVITES — Sofra davet kodları (S2: Cloud Function ile)
    // ═══════════════════════════════════════════

    match /invites/{inviteCode} {
      // Şimdilik sadece Cloud Functions (S2'de acceptInvite fonksiyonu eklenince)
      allow read, write: if false;
    }

    // ═══════════════════════════════════════════
    //  AI_USAGE — AI kullanım limitleri
    // ═══════════════════════════════════════════

    match /ai_usage/{dateId} {
      // Cloud Functions yazar, admin okuyabilir
      allow read: if isAdmin();
      allow write: if false; // Sadece Cloud Functions (service account) yazabilir
    }

    // ═══════════════════════════════════════════
    //  VARSAYILAN: Her şeyi reddet
    // ═══════════════════════════════════════════
    // Yukarıda tanımlanmamış herhangi bir koleksiyon otomatik reddedilir.
  }
}
